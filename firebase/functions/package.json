{
  "name": "sgm-hadir-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for SGM Hadir attendance system",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --config jest.config.js"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.15.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "firebase-functions-test": "^3.0.0"
  },
  "private": true
}
