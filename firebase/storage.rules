rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Selfie photos dari absensi
    match /attendances/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // Max 5MB
        && request.resource.contentType.matches('image/.*');
    }
    
    // Lampiran izin/cuti
    match /leave_attachments/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // Max 10MB
        && (request.resource.contentType.matches('image/.*') 
            || request.resource.contentType == 'application/pdf');
    }
    
    // Foto profil karyawan
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Foto kunjungan marketing
    match /visits/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Export files (Excel, PDF) - hanya bisa dibaca, ditulis oleh Cloud Functions
    match /exports/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Handled by Cloud Functions admin SDK
    }
  }
}
