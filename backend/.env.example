# SGM Hadir - Backend Server Environment Variables

# SERVER CONFIG
PORT=8080
GIN_MODE=debug # debug or release
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# DATABASE (PostgreSQL)
# Format: host=localhost user=gorm password=gorm dbname=gorm port=9920 sslmode=disable TimeZone=Asia/Jakarta
DATABASE_URL="host=localhost user=sgm_admin password=sgm_secret dbname=sgm_hadir port=5432 sslmode=disable TimeZone=Asia/Jakarta"

# REDIS (Session & Cache)
REDIS_URL="redis://localhost:6379/0"

# JWT CONFIG
JWT_SECRET="super-secret-jwt-key-change-this-in-production"
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# FIREBASE CLOUD MESSAGING (FCM)
# Path to the downloaded service account key JSON file
FCM_CREDENTIALS_PATH="./firebase-adminsdk.json"

# SUPABASE STORAGE (For Selfies & Attachments)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="sgm-hadir-bucket"
